# .env.example

# App
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://visaflow_user:visaflow_password@localhost:5432/visaflow_db?schema=public"

# Auth (Supabase Auth)
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT (Fallback / Independent Session Management)
JWT_SECRET="visaflow-super-secret-jwt-key-2026-change-me"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="visaflow-super-secret-refresh-key-2026-change-me"
JWT_REFRESH_EXPIRES_IN="7d"

# Storage (Supabase Storage)
STORAGE_BUCKET=visaflow

# Email
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@visaflow.ai
EMAIL_API_KEY=

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"
