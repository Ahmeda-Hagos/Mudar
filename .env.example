# .env.example

# App
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001

# Database (AWS RDS / Supabase PostgreSQL)
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<RDS_ENDPOINT>:5432/<DB_NAME>?schema=public"

# Auth (Supabase Auth)
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT (Fallback / Independent Session Management)
JWT_SECRET="<REDACTED_JWT_SECRET>"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="<REDACTED_JWT_REFRESH_SECRET>"
JWT_REFRESH_EXPIRES_IN="7d"

# Storage (AWS S3 - Riyadh me-central-2 Region)
AWS_REGION=me-central-2
AWS_ACCESS_KEY_ID=<REDACTED_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<REDACTED_AWS_SECRET_KEY>
AWS_S3_BUCKET=visaflow-sensitive-vault

# Redis (BullMQ / Background Jobs Queue)
REDIS_URL=redis://localhost:6379

# Email Notification Configuration
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@visaflow.ai
EMAIL_API_KEY=<REDACTED_EMAIL_PROVIDER_API_KEY>
